material Depth
{
	vertex_shader
	{
		file depthWrite.hlsl
		entry VSMain
		profile vs_6_6
	}
}

material DepthCullNone : Depth
{
	culling none
}

material DepthInstancing : Depth
{
	shader_defines ALPHA_TEST
}

material DepthAlpha : Depth
{
	pixel_shader
	{
		file depthWrite.hlsl
		entry PSMain
		profile ps_6_6
	}

	texture Diffuse

	shader_defines ALPHA_TEST
}

material DepthAlphaCullNone : DepthAlpha
{
	culling none
}
