material EntityId
{
	vertex_shader
	{
		file debug/entityId.hlsl
		entry VSMain
		profile vs_6_6
	}

	pixel_shader
	{
		file debug/entityId.hlsl
		entry PSMain
		profile ps_6_6
	}
}

material EntityIdCullNone : EntityId
{
	culling none
}

material EntityIdInstancing : EntityId
{
	shader_defines INSTANCED
}
